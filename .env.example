# ---------------------------------------------------------------------------
# Desktop build (Tauri) — these VITE_* vars are embedded into the frontend.
# ---------------------------------------------------------------------------
# Google OAuth (create clients at https://console.cloud.google.com/apis/credentials)
# Enable Google Drive API for the project.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Desktop builds only. DO NOT set this for the web build: the cloud server
# performs the Google OAuth exchange and keeps the secret server-side.
VITE_GOOGLE_CLIENT_SECRET=your-desktop-client-secret

# Optional: point the web frontend at a non-same-origin API during local dev
# (e.g. when running Vite on :1420 and the server on :3000).
# VITE_API_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Cloud web server (health-tracker-server) — set as deployment secrets/env,
# NOT in the frontend bundle. Listed here for documentation only.
# ---------------------------------------------------------------------------
# APP_PASSWORD=choose-a-strong-password         # required: single-user login
# SESSION_SECRET=64+ random bytes               # signs session cookies
# DATABASE_PATH=/data/tracker.db                # SQLite path on the volume
# PORT=8080
# SECURE_COOKIES=true                           # set false only for local http
# WEB_BASE_URL=https://your-app.fly.dev         # public URL (OAuth redirects)
# GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-web-client-secret
# GOOGLE_REDIRECT_URI=https://your-app.fly.dev/api/auth/google/callback
# WEB_CORS_ORIGINS=http://localhost:1420        # only needed for split dev
